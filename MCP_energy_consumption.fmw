FACTORY_DEF * TeeFactory   FACTORY_NAME "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   INPUT FEATURE_TYPE *  OUTPUT FEATURE_TYPE *
# -------------------------------------------------------------------------
MACRO FeatureReader_2_OUTPUT_PORTS_ENCODED PublicBuildings
MACRO FeatureReader_2_DIRECTIVES COORDINATE_SYSTEM,,EXPOSE_ATTRS_GROUP,,FLATTEN_MODE,ALL_LEVELS,GEOJSON_EXPOSE_FORMAT_ATTRS,,SPATIAL_GROUP,,USE_BASENAME_AS_DEFAULT_FEATURE_TYPE,Yes,USE_SEARCH_ENVELOPE,NO
# Always provide an INTERACTION, otherwise the factory defaults to ENVELOPE_INTERSECTS
INCLUDE [if { ( {NONE} == {<Unused>} ) || ( {($INTERACT)} == {} ) } {             puts {MACRO FCTQUERY_INTERACTION_LINE FCTQUERY_INTERACTION NONE};          } else {             puts {MACRO FCTQUERY_INTERACTION_LINE FCTQUERY_INTERACTION "NONE"};          }         ]
# Consolidate the attribute merge options to what the factory expects
DEFAULT_MACRO FeatureReader_2_COMBINE_ATTRS
INCLUDE [       if { {RESULT_ONLY} == {MERGE} } {          puts "MACRO FeatureReader_2_COMBINE_ATTRS <Unused>";       } else {          puts "MACRO FeatureReader_2_COMBINE_ATTRS RESULT_ONLY";       };    ]
INCLUDE [    puts {DEFAULT_MACRO FeatureReaderDataset_FeatureReader_2 @EvaluateExpression(FDIV,STRING_ENCODED,$(FME_MF_DIR_ENCODED)public-buildings.geojson,FeatureReader_2)}; ]
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { FeatureReader_2_Creator }    OUTPUT { FEATURE_TYPE FeatureReader_2_____CREATED______ }
FACTORY_DEF {*} QueryFactory    FACTORY_NAME { FeatureReader_2 }    INPUT { FEATURE_TYPE FeatureReader_2_____CREATED______ }    INPUT INITIATOR FEATURE_TYPE Creator_2_CREATED    $(FCTQUERY_INTERACTION_LINE)    CLIP_TO_INITIATOR_ENVELOPE { "NO" }    COMBINE_ATTRIBUTES  { $(FeatureReader_2_COMBINE_ATTRS) }    IGNORE_NULLS        { <Unused> }    REJECT_POINTS       { YES }    QUERYFCT_ATTRIBUTE_PREFIX { <Unused> }    COMBINE_GEOMETRY    { RESULT_ONLY }    ENABLE_CACHE        { NO }    QUERYFCT_TABLE_SEPARATOR { SPACE }    READER_TYPE         { GEOJSON  }    READER_DATASET      { "$(FeatureReaderDataset_FeatureReader_2)" }    QUERYFCT_IDS        { "PublicBuildings" }    QUERYFCT_IDS_FORMAT WWJD_PARTS    READER_DIRECTIVES   { METAFILE,GEOJSON }    QUERYFCT_OUTPUT     { "BASED_ON_CONNECTIONS" }    QUERYFCT_ADD_SCHEMA { "NO" }    QUERYFCT_USE_SCHEMA_CACHE { "YES" }    QUERYFCT_INITIATOR_FIRST_OUTPUT { "default" }    QUERYFCT_DEDUPE_GEOM YES    CONTINUE_ON_READER_ERROR YES    ORDER_RESULTS { "No" }    QUERYFCT_RESULT_TAGS { $(FeatureReader_2_OUTPUT_PORTS_ENCODED) }    QUERYFCT_SET_FME_FEATURE_TYPE YES    QUERYFCT_SET_FME_META_ATTRS YES    READER_PARAMS_WWJD     { $(FeatureReader_2_DIRECTIVES) }    TREAT_READER_PARAM_AMPERSANDS_AS_LITERALS YES    HONOR_INITIATOR_COORDSYS YES    OUTPUT { READER_ERROR FEATURE_TYPE FeatureReader_2_<REJECTED>           }    OUTPUT PublicBuildings FEATURE_TYPE FeatureReader_2_PublicBuildings
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME FeatureReader_2_<Rejected> INPUT FEATURE_TYPE FeatureReader_2_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, FeatureReader_2<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Log<space>and<space>Troubleshoot<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
Tcl2 proc ParameterFetcher_doFetch {} {    foreach {name val} {"_LIMIT {$(LIMIT$encode)} _POSTAL_CODE {$(POSTAL_CODE$encode)} _YEAR {$(YEAR$encode)}"} {         if { [string match {*<at>*} $val] == 1 } {             set val [FME_Execute EvaluateExpression {STRING} $val {ParameterFetcher}];         } elseif {[string match {*FME_CONDITIONAL*} $val] == 1} {             set val [FME_Execute EvaluateExpression {STRING} $val {ParameterFetcher}];         } else {             set val [FME_DecodeTextOrAttr $val];         };       FME_SetAttribute [FME_DecodeText $name] $val    } }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { ParameterFetcher }    INPUT  FEATURE_TYPE Creator_CREATED    OUTPUT { FEATURE_TYPE ParameterFetcher_OUTPUT         @Tcl2(ParameterFetcher_doFetch)          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} NullAttributeMapperFactory    FACTORY_NAME { NullAttributeMapper }    INPUT  FEATURE_TYPE ParameterFetcher_OUTPUT    ATTRCHOICE { ALL }    ATTRLIST { <Unused> }    SOURCE_ATTR_VAL { EMPTY }    OTHER_VAL { "" }    REG_EXPR { "" }    NULL_TREATMENT { DELETEATTR }    NEW_VAL { "<Unused>" }    OUTPUT { OUTPUT FEATURE_TYPE NullAttributeMapper_OUTPUT }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringValueFactory    FACTORY_NAME { StringCaseChanger }    INPUT  FEATURE_TYPE NullAttributeMapper_OUTPUT    FACTORY_MODE ATTRIBUTE_CASE_CHANGER    ATTRCHOICE { SELECTED }       ATTRLIST { _POSTAL_CODE }       CHANGE_TYPE { upper }    OUTPUT { OUTPUT FEATURE_TYPE StringCaseChanger_OUTPUT          }
# -------------------------------------------------------------------------
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { AttributeCreator_Creator }    OUTPUT { FEATURE_TYPE AttributeCreator_____CREATED______ }
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT { FEATURE_TYPE AttributeCreator_____CREATED______ }    INPUT  FEATURE_TYPE StringCaseChanger_OUTPUT    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_YEAR_REQUEST" "SET_TO" "FME_CONDITIONAL:DEFAULT_VALUE'1<space>=<space>1'BOOL_OP;OR;COMPOSITE_TEST;1;TEST _YEAR ATTRIBUTE_HAS_A_VALUE _FME_BLANK_STRING_'<quote>Year<quote><space>=<space><at>Value<openparen>_YEAR<closeparen>'FME_NUM_CONDITIONS2___" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_POSTAL_CODE_REQUEST" "SET_TO" "FME_CONDITIONAL:DEFAULT_VALUE'1<space>=<space>1'BOOL_OP;AND;COMPOSITE_TEST;1 AND 2 AND 3;TEST _POSTAL_CODE ATTRIBUTE_HAS_A_VALUE _FME_BLANK_STRING_;TEST <at>StringLength<openparen><at>Value<openparen>_POSTAL_CODE<closeparen><closeparen> = 3;CASE_SENSITIVE_TEST <at>Value<openparen>_POSTAL_CODE<closeparen> CONTAINS_REGEX ^<openbracket>A-Z<closebracket><backslash>d<openbracket>A-Z<closebracket><dollar>'<quote>Postal<space>Code<quote><space>LIKE<space><apos><at>Value<openparen>_POSTAL_CODE<closeparen>%<apos>'BOOL_OP;AND;COMPOSITE_TEST;1 AND 2 AND 3;TEST _POSTAL_CODE ATTRIBUTE_HAS_A_VALUE _FME_BLANK_STRING_;CASE_SENSITIVE_TEST <at>Value<openparen>_POSTAL_CODE<closeparen> CONTAINS_REGEX ^<openbracket>A-Z<closebracket><backslash>d<openbracket>A-Z<closebracket><space><backslash>d<openbracket>A-Z<closebracket><backslash>d<dollar>;TEST <at>StringLength<openparen><at>Value<openparen>_POSTAL_CODE<closeparen><closeparen> = 7'<quote>Postal<space>Code<quote><space>=<space><apos><at>Value<openparen>_POSTAL_CODE<closeparen><apos>'FME_NUM_CONDITIONS3___" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_OUTPUT        }
# -------------------------------------------------------------------------
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { AttributeCreator_2_Creator }    OUTPUT { FEATURE_TYPE AttributeCreator_2_____CREATED______ }
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT { FEATURE_TYPE AttributeCreator_2_____CREATED______ }    INPUT  FEATURE_TYPE AttributeCreator_OUTPUT    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "WHERE_Query" "SET_TO" "<at>Value<openparen>_POSTAL_CODE_REQUEST<closeparen><space>AND<space><at>Value<openparen>_YEAR_REQUEST<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_2_OUTPUT        }
