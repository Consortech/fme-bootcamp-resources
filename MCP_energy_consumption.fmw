FME_PYTHON_VERSION 310
ARCGIS_COMPATIBILITY ARCGIS_AUTO
GUI IGNORE DestDataset_MCP_1
# ============================================================================
DEFAULT_MACRO POSTAL_CODE M9V

DEFAULT_MACRO YEAR 2024

DEFAULT_MACRO LIMIT 30

DEFAULT_MACRO DestDataset_MCP 

# ============================================================================
INCLUDE [ if {{$(DestDataset_MCP$encode)} == {}} { puts_real {Parameter 'DestDataset_MCP' must be given a value.}; exit 1; }; ]
#! START_HEADER
#! START_WB_HEADER
READER_TYPE MULTI_READER
WRITER_TYPE MULTI_WRITER
WRITER_KEYWORD PRIMARY_DEST
PRIMARY_DEST_DATASET_ORDER BY_ID
PRIMARY_DEST_FIRST_WRITER_ID 0
PRIMARY_DEST_TYPE{0} MCP
PRIMARY_DEST_KEYWORD{0} MCP_1
PRIMARY_DEST_GEN_DIRECTIVES{0} _CS_SPATIAL_GROUP,,ADD_WRITER_NEXT_ACTION,none,COORDINATE_SYSTEM,
#! END_WB_HEADER
#! START_WB_HEADER
MACRO WB_KEYWORD "MCP_1"
#! END_WB_HEADER
#! START_DEST_HEADER MCP MCP_1
#! END_DEST_HEADER
#! START_WB_HEADER
DEFAULT_MACRO DestDataset
INCLUDE [ if {"$(DestDataset)" != ""} {                          \
 puts {DEFAULT_MACRO DestDataset_MCP_1 $(DestDataset)}         \
 } ]
#! END_WB_HEADER
#! START_DEST_HEADER MCP MCP_1
DEFAULT_MACRO DestDataset_MCP_1 $(DestDataset_MCP)
GUI DIRNAME DestDataset_MCP_1 Destination MCP Folder:
# ============================================================================
MCP_1_GENERATE_FME_BUILD_NUM 26299
MCP_1_DATASET "$(DestDataset_MCP_1)"
#! END_DEST_HEADER
#! START_WB_HEADER
#! END_WB_HEADER
#! END_HEADER

LOG_FILENAME "$(FME_MF_DIR)$(WORKSPACE_NAME).log"
LOG_APPEND NO
LOG_MAX_FEATURES 200
LOG_MAX_RECORDED_FEATURES 200
FME_REPROJECTION_ENGINE FME
FME_IMPLICIT_CSMAP_REPROJECTION_MODE Auto
FME_GEOMETRY_HANDLING Enhanced
FME_STROKE_MAX_DEVIATION 0
FME_NAMES_ENCODING UTF-8
FME_BULK_MODE_THRESHOLD 2000
LAST_SAVE_BUILD "FME 2026.1.0.0 (20260311 - Build 26103 - WIN64)"
DEFAULT_MACRO DATASET_KEYWORD_MCP_1 MCP_1
# -------------------------------------------------------------------------

MULTI_READER_CONTINUE_ON_READER_FAILURE No

# -------------------------------------------------------------------------

MACRO FME_VIEWER_APP fmedatainspector
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
Tcl2 proc Creator_CoordSysRemover {} {   global FME_CoordSys;   set FME_CoordSys {}; }
MACRO Creator_XML     NOT_ACTIVATED
MACRO Creator_GEOJSON NOT_ACTIVATED
MACRO Creator_NOGEOM NOT_ACTIVATED
INCLUDE [ if { {No Geometry} == {Geometry Object} } {            puts {MACRO Creator_XML *} } ]
INCLUDE [ if { {No Geometry} == {GeoJSON} } {            puts {MACRO Creator_GEOJSON *} } ]
INCLUDE [ if { {No Geometry} == {No Geometry} } {            puts {MACRO Creator_NOGEOM *} } ]
FACTORY_DEF {$(Creator_XML)} CreationFactory    FACTORY_NAME { Creator_XML_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(FROM_ENCODED_STRING,<Unused>) }
FACTORY_DEF {$(Creator_GEOJSON)} CreationFactory    FACTORY_NAME { Creator_GEOJSON_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @SupplyAttributes(ENCODED,__GeoJSONCreatorTemp__,<Unused>)        @JSONGeometry(FROM_ATTRIBUTE,GEOJSON,__GeoJSONCreatorTemp__, PREFER_ERROR_OVER_REJECTION)        @RemoveAttributes(__GeoJSONCreatorTemp__) }
FACTORY_DEF {$(Creator_NOGEOM)} CreationFactory    FACTORY_NAME { Creator_NOGEOM_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(CREATE_NO_GEOMETRY) }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Creator_Cloner }    INPUT FEATURE_TYPE _____CREATED______        @Tcl2(Creator_CoordSysRemover)        @CoordSys(<Unused>)    NUMBER_OF_COPIES { 1 }    COPY_NUMBER_ATTRIBUTE { "_creation_instance" }    OUTPUT { FEATURE_TYPE Creator_CREATED        fme_feature_type Creator         }
FACTORY_DEF * BranchingFactory   FACTORY_NAME "Creator_CREATED Brancher -1 16"   INPUT FEATURE_TYPE Creator_CREATED   TARGET_FACTORY "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   MAXIMUM_COUNT None   OUTPUT PASSED FEATURE_TYPE *
# -------------------------------------------------------------------------
Tcl2 proc Creator_2_CoordSysRemover {} {   global FME_CoordSys;   set FME_CoordSys {}; }
MACRO Creator_2_XML     NOT_ACTIVATED
MACRO Creator_2_GEOJSON NOT_ACTIVATED
MACRO Creator_2_NOGEOM NOT_ACTIVATED
INCLUDE [ if { {No Geometry} == {Geometry Object} } {            puts {MACRO Creator_2_XML *} } ]
INCLUDE [ if { {No Geometry} == {GeoJSON} } {            puts {MACRO Creator_2_GEOJSON *} } ]
INCLUDE [ if { {No Geometry} == {No Geometry} } {            puts {MACRO Creator_2_NOGEOM *} } ]
FACTORY_DEF {$(Creator_2_XML)} CreationFactory    FACTORY_NAME { Creator_2_XML_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(FROM_ENCODED_STRING,<Unused>) }
FACTORY_DEF {$(Creator_2_GEOJSON)} CreationFactory    FACTORY_NAME { Creator_2_GEOJSON_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @SupplyAttributes(ENCODED,__GeoJSONCreatorTemp__,<Unused>)        @JSONGeometry(FROM_ATTRIBUTE,GEOJSON,__GeoJSONCreatorTemp__, PREFER_ERROR_OVER_REJECTION)        @RemoveAttributes(__GeoJSONCreatorTemp__) }
FACTORY_DEF {$(Creator_2_NOGEOM)} CreationFactory    FACTORY_NAME { Creator_2_NOGEOM_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(CREATE_NO_GEOMETRY) }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Creator_2_Cloner }    INPUT FEATURE_TYPE _____CREATED______        @Tcl2(Creator_2_CoordSysRemover)        @CoordSys(<Unused>)    NUMBER_OF_COPIES { 1 }    COPY_NUMBER_ATTRIBUTE { "_creation_instance" }    OUTPUT { FEATURE_TYPE Creator_2_CREATED        fme_feature_type Creator_2         }
FACTORY_DEF * BranchingFactory   FACTORY_NAME "Creator_2_CREATED Brancher -1 17"   INPUT FEATURE_TYPE Creator_2_CREATED   TARGET_FACTORY "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   MAXIMUM_COUNT None   OUTPUT PASSED FEATURE_TYPE *
