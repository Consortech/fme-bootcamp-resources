FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { AttributeCreator_Creator }    OUTPUT { FEATURE_TYPE AttributeCreator_____CREATED______ }
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT { FEATURE_TYPE AttributeCreator_____CREATED______ }    INPUT  FEATURE_TYPE JSONTemplater_OUTPUT    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "response.status_code" "SET_TO" "200" "uint8" }      ATTR_ACTION { "" "response.body.content_type" "SET_TO" "application<solidus>json" "varchar<openparen>16<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_OUTPUT        }
# -------------------------------------------------------------------------
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { AttributeCreator_2_Creator }    OUTPUT { FEATURE_TYPE AttributeCreator_2_____CREATED______ }
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT { FEATURE_TYPE AttributeCreator_2_____CREATED______ }    INPUT  FEATURE_TYPE Tester_FAILED    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "response.status_code" "SET_TO" "204" "uint8" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_2_OUTPUT        }
# -------------------------------------------------------------------------
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { AttributeCreator_4_Creator }    OUTPUT { FEATURE_TYPE AttributeCreator_4_____CREATED______ }
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator_4 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT { FEATURE_TYPE AttributeCreator_4_____CREATED______ }    INPUT  FEATURE_TYPE TestFilter_Invalid<space>Parameters    INPUT  FEATURE_TYPE TestFilter_2_Invalid<space>Parameters    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "response.status_code" "SET_TO" "400" "uint16" }      ATTR_ACTION { "" "response.body.content" "SET_TO" "<opencurly><quote>ErrorMessage<quote>:<quote>Invalid<space>parameter<space>value<quote><closecurly>" "varchar<openparen>42<closeparen>" }      ATTR_ACTION { "" "response.body.content_type" "SET_TO" "application<solidus>json" "varchar<openparen>16<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_4_OUTPUT        }
